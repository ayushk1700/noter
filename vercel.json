{
  "buildCommand": "next build",
  "devCommand": "next dev",
  "installCommand": "npm install",
  "framework": "nextjs",
  "env": {
    "NEXT_PUBLIC_APP_NAME": {
      "description": "Application name",
      "required": false
    },
    "NEXT_PUBLIC_APP_DESCRIPTION": {
      "description": "Application description",
      "required": false
    }
  },
  "regions": ["sfo1"],
  "functions": {
    "app/api/**/*.ts": {
      "memory": 1024,
      "maxDuration": 30
    }
  }
}
